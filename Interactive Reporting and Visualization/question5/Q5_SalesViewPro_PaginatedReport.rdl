          <!-- ══════════════════════════════════════════════════════
               RECTANGLE 2 — EXECUTIVE KPI SUMMARY (PAGE 2)
          ══════════════════════════════════════════════════════ -->
          <Rectangle Name="RECT_KPI">
            <Top>9.1in</Top><Left>0in</Left><Width>6.5in</Width><Height>9in</Height>
            <PageBreak><BreakLocation>After</BreakLocation></PageBreak>
            <ReportItems>

              <!-- Section heading -->
              <Textbox Name="KPI_Heading">
                <CanGrow>false</CanGrow>
                <Top>0in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.4in</Height>
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>Executive Summary — Key Performance Indicators</Value>
                  <Style><FontFamily>Arial</FontFamily><FontSize>14pt</FontSize>
                         <FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                </TextRun></TextRuns></Paragraph></Paragraphs>
                <Style><VerticalAlign>Middle</VerticalAlign>
                       <BorderStyle><Bottom>Solid</Bottom></BorderStyle>
                       <BorderColor><Bottom>#2E75B6</Bottom></BorderColor>
                       <BorderWidth><Bottom>2pt</Bottom></BorderWidth></Style>
              </Textbox>

              <!-- Dynamic period label -->
              <Textbox Name="KPI_PeriodLabel">
                <CanGrow>false</CanGrow>
                <Top>0.5in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.25in</Height>
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>="Current View: " &amp; Switch(
  Parameters!DateRange.Value="YTD","Year to Date",
  Parameters!DateRange.Value="LastQuarter","Last Quarter",
  Parameters!DateRange.Value="Last12Months","Last 12 Months",
  Parameters!DateRange.Value="2024","Full Year 2024",
  Parameters!DateRange.Value="2023","Full Year 2023",
  True, Parameters!DateRange.Value
) &amp; "  /  " &amp; Switch(
  Parameters!RegionSegment.Value="All","All Regions",
  True, Parameters!RegionSegment.Value
)</Value>
                  <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize>
                         <FontStyle>Italic</FontStyle><Color>#2E75B6</Color></Style>
                </TextRun></TextRuns></Paragraph></Paragraphs>
              </Textbox>

              <!-- KPI metrics table — dataset driven -->
              <Tablix Name="KPI_Table">
                <DataSetName>DS_KPISummary</DataSetName>
                <Top>0.85in</Top><Left>0in</Left><Width>6.5in</Width><Height>1in</Height>
                <TablixBody>
                  <TablixColumns>
                    <TablixColumn><Width>1.625in</Width></TablixColumn>
                    <TablixColumn><Width>1.625in</Width></TablixColumn>
                    <TablixColumn><Width>1.625in</Width></TablixColumn>
                    <TablixColumn><Width>1.625in</Width></TablixColumn>
                  </TablixColumns>
                  <TablixRows>
                    <!-- Row 1: Values -->
                    <TablixRow>
                      <Height>0.5in</Height>
                      <TablixCells>
                        <TablixCell><CellContents><Textbox Name="KV_Revenue"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>=Format(First(Fields!TotalRevenue.Value, "DS_KPISummary"),"$#,##0")</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#D6E4F0</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                        <TablixCell><CellContents><Textbox Name="KV_Orders"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>=Format(First(Fields!TotalOrders.Value, "DS_KPISummary"),"#,##0")</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#2E75B6</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#D6E4F0</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                        <TablixCell><CellContents><Textbox Name="KV_Margin"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>=Format(First(Fields!ProfitMargin.Value, "DS_KPISummary"),"0.0") &amp; "%"</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#1D7A4E</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#D6E4F0</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                        <TablixCell><CellContents><Textbox Name="KV_AOV"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>=Format(First(Fields!AvgOrderValue.Value, "DS_KPISummary"),"$#,##0")</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>#F0A500</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#D6E4F0</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                      </TablixCells>
                    </TablixRow>
                    <!-- Row 2: Labels -->
                    <TablixRow>
                      <Height>0.3in</Height>
                      <TablixCells>
                        <TablixCell><CellContents><Textbox Name="KL_Revenue"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>Total Revenue</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#595959</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#F2F2F2</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                        <TablixCell><CellContents><Textbox Name="KL_Orders"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>Total Orders</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#595959</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#F2F2F2</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                        <TablixCell><CellContents><Textbox Name="KL_Margin"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>Profit Margin</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#595959</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#F2F2F2</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                        <TablixCell><CellContents><Textbox Name="KL_AOV"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><Style><TextAlign>Center</TextAlign></Style><TextRuns><TextRun>
                          <Value>Avg Order Value</Value>
                          <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#595959</Color></Style>
                          </TextRun></TextRuns></Paragraph></Paragraphs>
                          <Style><BackgroundColor>#F2F2F2</BackgroundColor><VerticalAlign>Middle</VerticalAlign>
                          <BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>#CCCCCC</Default></BorderColor><BorderWidth><Default>0.5pt</Default></BorderWidth>
                          </Style></Textbox></CellContents></TablixCell>
                      </TablixCells>
                    </TablixRow>
                  </TablixRows>
                </TablixBody>
                <TablixColumnHierarchy>
                  <TablixMembers><TablixMember/><TablixMember/><TablixMember/><TablixMember/></TablixMembers>
                </TablixColumnHierarchy>
                <TablixRowHierarchy>
                  <TablixMembers><TablixMember/><TablixMember/></TablixMembers>
                </TablixRowHierarchy>
              </Tablix>

              <!-- ── VISUALIZATION 1: Revenue Trend Chart (Line) ─── -->
              <Textbox Name="CH_RevHeading">
                <CanGrow>false</CanGrow>
                <Top>2.1in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.35in</Height>
                <Paragraphs><Paragraph><TextRuns><TextRun>
                  <Value>Visualization 1 — Quarterly Revenue Trend</Value>
                  <Style><FontFamily>Arial</FontFamily><FontSize>11pt</FontSize><FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                </TextRun></TextRuns></Paragraph></Paragraphs>
                <Style><VerticalAlign>Middle</VerticalAlign>
                       <BorderStyle><Bottom>Solid</Bottom></BorderStyle>
                       <BorderColor><Bottom>#2E75B6</Bottom></BorderColor>
                       <BorderWidth><Bottom>1.5pt</Bottom></BorderWidth></Style>
              </Textbox>

              <Chart Name="CH_RevenueTrend">
                <DataSetName>DS_QuarterlyRevenue</DataSetName>
                <Top>2.55in</Top><Left>0in</Left><Width>6.5in</Width><Height>3in</Height>
                <ChartSeriesCollection>
                  <ChartSeries Name="Revenue">
                    <ChartDataPoints>
                      <ChartDataPoint>
                        <ChartDataPointValues>
                          <Y>=Fields!Revenue.Value</Y>
                        </ChartDataPointValues>
                        <Style>
                          <Color>#2E75B6</Color>
                        </Style>
                      </ChartDataPoint>
                    </ChartDataPoints>
                    <ChartSeriesGroupings>
                      <ChartSeriesGrouping>
                        <ChartGroupExpressions>
                          <ChartGroupExpression>=Fields!YearNum.Value</ChartGroupExpression>
                        </ChartGroupExpressions>
                        <Label>=Fields!YearNum.Value</Label>
                      </ChartSeriesGrouping>
                    </ChartSeriesGroupings>
                    <Style>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderColor><Default>#2E75B6</Default></BorderColor>
                      <BorderWidth><Default>2pt</Default></BorderWidth>
                    </Style>
                    <Type>Line</Type>
                    <ChartMarker>
                      <MarkerType>Circle</MarkerType>
                      <Size>6</Size>
                      <Style><Color>#1E3A5F</Color></Style>
                    </ChartMarker>
                  </ChartSeries>
                  <ChartSeries Name="Profit">
                    <ChartDataPoints>
                      <ChartDataPoint>
                        <ChartDataPointValues>
                          <Y>=Fields!Profit.Value</Y>
                        </ChartDataPointValues>
                      </ChartDataPoint>
                    </ChartDataPoints>
                    <ChartSeriesGroupings>
                      <ChartSeriesGrouping>
                        <ChartGroupExpressions>
                          <ChartGroupExpression>=Fields!YearNum.Value</ChartGroupExpression>
                        </ChartGroupExpressions>
                        <Label>=Fields!YearNum.Value</Label>
                      </ChartSeriesGrouping>
                    </ChartSeriesGroupings>
                    <Style>
                      <BorderStyle><Default>Solid</Default></BorderStyle>
                      <BorderColor><Default>#1D7A4E</Default></BorderColor>
                      <BorderWidth><Default>2pt</Default></BorderWidth>
                    </Style>
                    <Type>Line</Type>
                    <ChartMarker>
                      <MarkerType>Diamond</MarkerType>
                      <Size>6</Size>
                      <Style><Color>#1D7A4E</Color></Style>
                    </ChartMarker>
                  </ChartSeries>
                </ChartSeriesCollection>
                <ChartCategoryHierarchy>
                  <ChartMembers>
                    <ChartMember>
                      <Group Name="CatGroup">
                        <GroupExpressions>
                          <GroupExpression>=Fields!YearQuarter.Value</GroupExpression>
                        </GroupExpressions>
                      </Group>
                      <Label>=Fields!YearQuarter.Value</Label>
                    </ChartMember>
                  </ChartMembers>
                </ChartCategoryHierarchy>
                <ChartAreas>
                  <ChartArea Name="Default">
                    <ChartCategoryAxes>
                      <ChartAxis Name="CategoryAxis">
                        <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#595959</Color></Style>
                        <Title>
                          <Caption>Year / Quarter</Caption>
                          <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                        </Title>
                      </ChartAxis>
                    </ChartCategoryAxes>
                    <ChartValueAxes>
                      <ChartAxis Name="ValueAxis">
                        <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize><Color>#595959</Color></Style>
                        <Title>
