<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">

  <!-- ═══════════════════════════════════════════════════════════════════
       REPORT PARAMETERS
       Two parameters as required by Question 5:
         1. DateRange  — controls the reporting period for all datasets
         2. RegionSegment — filters data by region or customer segment
  ═══════════════════════════════════════════════════════════════════ -->
  <ReportParameters>

    <ReportParameter Name="DateRange">
      <DataType>String</DataType>
      <DefaultValue>
        <Values><Value>YTD</Value></Values>
      </DefaultValue>
      <Prompt>Reporting Period</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue><Value>YTD</Value><Label>Year to Date (YTD)</Label></ParameterValue>
          <ParameterValue><Value>LastQuarter</Value><Label>Last Quarter</Label></ParameterValue>
          <ParameterValue><Value>Last12Months</Value><Label>Last 12 Months</Label></ParameterValue>
          <ParameterValue><Value>2024</Value><Label>Full Year 2024</Label></ParameterValue>
          <ParameterValue><Value>2023</Value><Label>Full Year 2023</Label></ParameterValue>
          <ParameterValue><Value>2022</Value><Label>Full Year 2022</Label></ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>

    <ReportParameter Name="RegionSegment">
      <DataType>String</DataType>
      <DefaultValue>
        <Values><Value>All</Value></Values>
      </DefaultValue>
      <Prompt>Region / Customer Segment</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue><Value>All</Value><Label>All Regions / All Segments</Label></ParameterValue>
          <ParameterValue><Value>South</Value><Label>South Region</Label></ParameterValue>
          <ParameterValue><Value>East</Value><Label>East Region</Label></ParameterValue>
          <ParameterValue><Value>West</Value><Label>West Region</Label></ParameterValue>
          <ParameterValue><Value>North</Value><Label>North Region</Label></ParameterValue>
          <ParameterValue><Value>Business</Value><Label>Business Segment</Label></ParameterValue>
          <ParameterValue><Value>Consumer</Value><Label>Consumer Segment</Label></ParameterValue>
          <ParameterValue><Value>Enterprise</Value><Label>Enterprise Segment</Label></ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>

  </ReportParameters>

  <!-- ═══════════════════════════════════════════════════════════════════
       DATA SOURCES
       Replace ConnectString with your actual SQL Server / Power BI
       Premium dataset connection string before deploying.
  ═══════════════════════════════════════════════════════════════════ -->
  <DataSources>
    <DataSource Name="SalesViewPro">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=YOUR_SERVER;Initial Catalog=SalesViewProDB;Integrated Security=True</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
    </DataSource>
  </DataSources>

  <!-- ═══════════════════════════════════════════════════════════════════
       DATASETS
       All datasets accept @DateRange and @RegionSegment parameters.
       Replace the placeholder SELECT statements with your actual queries.
  ═══════════════════════════════════════════════════════════════════ -->
  <DataSets>

    <!-- DS 1: Top-line KPI metrics -->
    <DataSet Name="DS_KPISummary">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange">
            <Value>=Parameters!DateRange.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@RegionSegment">
            <Value>=Parameters!RegionSegment.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT
            SUM(s.NetSaleAmount)                          AS TotalRevenue,
            COUNT(DISTINCT s.OrderID)                     AS TotalOrders,
            ROUND(SUM(s.NetProfit)/SUM(s.NetSaleAmount)*100,1) AS ProfitMargin,
            ROUND(SUM(s.NetSaleAmount)/COUNT(DISTINCT s.OrderID),0) AS AvgOrderValue,
            COUNT(DISTINCT s.CustomerID)                  AS UniqueCustomers,
            ROUND(AVG(c.SatisfactionScore),1)             AS AvgSatisfaction,
            MAX(c.TotalRevenue)                           AS TopCustomerLTV,
            ROUND(AVG(s.DiscountPct)*100,1)               AS AvgDiscountRate
          FROM Sales s
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          WHERE
            (@DateRange = 'All'
              OR (@DateRange = 'YTD'          AND YEAR(s.OrderDate) = YEAR(GETDATE()))
              OR (@DateRange = 'LastQuarter'  AND s.OrderDate >= DATEADD(QUARTER,-1,DATETRUNC(QUARTER,GETDATE())))
              OR (@DateRange = 'Last12Months' AND s.OrderDate >= DATEADD(MONTH,-12,GETDATE()))
              OR (@DateRange = '2024'         AND YEAR(s.OrderDate) = 2024)
              OR (@DateRange = '2023'         AND YEAR(s.OrderDate) = 2023)
              OR (@DateRange = '2022'         AND YEAR(s.OrderDate) = 2022))
            AND
            (@RegionSegment = 'All'
              OR s.Region      = @RegionSegment
              OR c.Segment     = @RegionSegment)
        </CommandText>
      </Query>
      <Fields>
        <Field Name="TotalRevenue">    <DataField>TotalRevenue</DataField>    <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="TotalOrders">     <DataField>TotalOrders</DataField>     <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="ProfitMargin">    <DataField>ProfitMargin</DataField>    <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="AvgOrderValue">   <DataField>AvgOrderValue</DataField>   <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="UniqueCustomers"> <DataField>UniqueCustomers</DataField> <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="AvgSatisfaction"> <DataField>AvgSatisfaction</DataField> <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="TopCustomerLTV">  <DataField>TopCustomerLTV</DataField>  <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="AvgDiscountRate"> <DataField>AvgDiscountRate</DataField> <rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <!-- DS 2: Quarterly revenue trend for chart -->
    <DataSet Name="DS_QuarterlyRevenue">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange"><Value>=Parameters!DateRange.Value</Value></QueryParameter>
          <QueryParameter Name="@RegionSegment"><Value>=Parameters!RegionSegment.Value</Value></QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT
            CAST(YEAR(s.OrderDate) AS VARCHAR) + ' Q' + CAST(DATEPART(QUARTER,s.OrderDate) AS VARCHAR) AS YearQuarter,
            YEAR(s.OrderDate)           AS YearNum,
            DATEPART(QUARTER,s.OrderDate) AS QuarterNum,
            SUM(s.NetSaleAmount)        AS Revenue,
            SUM(s.NetProfit)            AS Profit,
            COUNT(DISTINCT s.OrderID)   AS Orders
          FROM Sales s
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          WHERE
            (@RegionSegment = 'All' OR s.Region = @RegionSegment OR c.Segment = @RegionSegment)
          GROUP BY YEAR(s.OrderDate), DATEPART(QUARTER,s.OrderDate)
          ORDER BY YEAR(s.OrderDate), DATEPART(QUARTER,s.OrderDate)
        </CommandText>
      </Query>
      <Fields>
        <Field Name="YearQuarter"><DataField>YearQuarter</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="YearNum">    <DataField>YearNum</DataField>    <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="QuarterNum"> <DataField>QuarterNum</DataField> <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="Revenue">    <DataField>Revenue</DataField>    <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Profit">     <DataField>Profit</DataField>     <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Orders">     <DataField>Orders</DataField>     <rd:TypeName>System.Int32</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <!-- DS 3: Category performance -->
    <DataSet Name="DS_CategoryPerformance">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange"><Value>=Parameters!DateRange.Value</Value></QueryParameter>
          <QueryParameter Name="@RegionSegment"><Value>=Parameters!RegionSegment.Value</Value></QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT
            p.Category,
            SUM(s.NetSaleAmount)                               AS Revenue,
            SUM(s.UnitsSold)                                   AS UnitsSold,
            ROUND(SUM(s.NetProfit)/NULLIF(SUM(s.NetSaleAmount),0)*100,1) AS ProfitMargin,
            ROUND(AVG(s.DiscountPct)*100,1)                    AS AvgDiscount
          FROM Sales s
          INNER JOIN Products p  ON s.ProductID  = p.ProductID
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          WHERE
            (@RegionSegment = 'All' OR s.Region = @RegionSegment OR c.Segment = @RegionSegment)
          GROUP BY p.Category
          ORDER BY Revenue DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="Category">    <DataField>Category</DataField>    <rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Revenue">     <DataField>Revenue</DataField>     <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="UnitsSold">   <DataField>UnitsSold</DataField>   <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="ProfitMargin"><DataField>ProfitMargin</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="AvgDiscount"> <DataField>AvgDiscount</DataField> <rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <!-- DS 4: Regional performance -->
    <DataSet Name="DS_RegionalPerformance">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange"><Value>=Parameters!DateRange.Value</Value></QueryParameter>
          <QueryParameter Name="@RegionSegment"><Value>=Parameters!RegionSegment.Value</Value></QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT
            s.Region,
            SUM(s.NetSaleAmount)             AS Revenue,
            COUNT(DISTINCT s.OrderID)        AS Orders,
            ROUND(SUM(s.NetSaleAmount)/SUM(SUM(s.NetSaleAmount)) OVER()*100,1) AS RevenueSharePct,
            SUM(s.NetSaleAmount) - SUM(t.TargetAmount) AS VsTarget
          FROM Sales s
          LEFT JOIN Targets t ON s.Region = t.Region
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          WHERE
            (@RegionSegment = 'All' OR s.Region = @RegionSegment OR c.Segment = @RegionSegment)
          GROUP BY s.Region
          ORDER BY Revenue DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="Region">          <DataField>Region</DataField>          <rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Revenue">         <DataField>Revenue</DataField>         <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Orders">          <DataField>Orders</DataField>          <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="RevenueSharePct"> <DataField>RevenueSharePct</DataField> <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="VsTarget">        <DataField>VsTarget</DataField>        <rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <!-- DS 5: Customer segment analysis -->
    <DataSet Name="DS_CustomerSegment">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange"><Value>=Parameters!DateRange.Value</Value></QueryParameter>
          <QueryParameter Name="@RegionSegment"><Value>=Parameters!RegionSegment.Value</Value></QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT
            c.Segment,
            SUM(s.NetSaleAmount)             AS Revenue,
            COUNT(DISTINCT s.CustomerID)     AS CustomerCount,
            ROUND(AVG(c.TotalRevenue),0)     AS AvgLTV,
            ROUND(AVG(c.SatisfactionScore),1) AS AvgSatisfaction
          FROM Sales s
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          WHERE
            (@RegionSegment = 'All' OR s.Region = @RegionSegment OR c.Segment = @RegionSegment)
          GROUP BY c.Segment
          ORDER BY Revenue DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="Segment">         <DataField>Segment</DataField>         <rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Revenue">         <DataField>Revenue</DataField>         <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="CustomerCount">   <DataField>CustomerCount</DataField>   <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="AvgLTV">          <DataField>AvgLTV</DataField>          <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="AvgSatisfaction"> <DataField>AvgSatisfaction</DataField> <rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <!-- DS 6: Budget vs Actual vs Target -->
    <DataSet Name="DS_BudgetActual">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange"><Value>=Parameters!DateRange.Value</Value></QueryParameter>
          <QueryParameter Name="@RegionSegment"><Value>=Parameters!RegionSegment.Value</Value></QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT
            p.Category,
            SUM(t.BudgetAmount)              AS Budget,
            SUM(t.TargetAmount)              AS Target,
            SUM(s.NetSaleAmount)             AS Actual,
            SUM(s.NetSaleAmount) - SUM(t.BudgetAmount) AS VsBudget,
            SUM(s.NetSaleAmount) - SUM(t.TargetAmount) AS VsTarget,
            ROUND((SUM(s.NetSaleAmount) - SUM(t.BudgetAmount))/NULLIF(SUM(t.BudgetAmount),0)*100,1) AS VsBudgetPct
          FROM Sales s
          INNER JOIN Products p  ON s.ProductID  = p.ProductID
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          LEFT  JOIN Targets t   ON p.Category   = t.Category
          WHERE
            (@RegionSegment = 'All' OR s.Region = @RegionSegment OR c.Segment = @RegionSegment)
          GROUP BY p.Category
          ORDER BY Actual DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="Category">   <DataField>Category</DataField>   <rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Budget">     <DataField>Budget</DataField>     <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Target">     <DataField>Target</DataField>     <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Actual">     <DataField>Actual</DataField>     <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="VsBudget">   <DataField>VsBudget</DataField>   <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="VsTarget">   <DataField>VsTarget</DataField>   <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="VsBudgetPct"><DataField>VsBudgetPct</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <!-- DS 7: Top 5 customers -->
    <DataSet Name="DS_TopCustomers">
      <Query>
        <DataSourceName>SalesViewPro</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DateRange"><Value>=Parameters!DateRange.Value</Value></QueryParameter>
          <QueryParameter Name="@RegionSegment"><Value>=Parameters!RegionSegment.Value</Value></QueryParameter>
        </QueryParameters>
        <CommandText>
          SELECT TOP 5
            ROW_NUMBER() OVER (ORDER BY SUM(s.NetSaleAmount) DESC) AS Rank,
            c.CustomerName,
            SUM(s.NetSaleAmount)   AS Revenue,
            c.Segment,
            c.SatisfactionScore    AS Satisfaction
          FROM Sales s
          INNER JOIN Customers c ON s.CustomerID = c.CustomerID
          WHERE
            (@RegionSegment = 'All' OR s.Region = @RegionSegment OR c.Segment = @RegionSegment)
          GROUP BY c.CustomerID, c.CustomerName, c.Segment, c.SatisfactionScore
          ORDER BY SUM(s.NetSaleAmount) DESC
        </CommandText>
      </Query>
      <Fields>
        <Field Name="Rank">         <DataField>Rank</DataField>         <rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="CustomerName"> <DataField>CustomerName</DataField> <rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Revenue">      <DataField>Revenue</DataField>      <rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Segment">      <DataField>Segment</DataField>      <rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Satisfaction"> <DataField>Satisfaction</DataField> <rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

  </DataSets>

  <!-- ═══════════════════════════════════════════════════════════════════
       REPORT SECTION — Page layout, header, footer, body
  ═══════════════════════════════════════════════════════════════════ -->
  <ReportSections>
    <ReportSection>

      <!-- ─── PAGE SETTINGS ─────────────────────────────────────────── -->
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <LeftMargin>1in</LeftMargin>
        <RightMargin>1in</RightMargin>
        <TopMargin>0.75in</TopMargin>
        <BottomMargin>0.75in</BottomMargin>

        <!-- PAGE HEADER: Company name | Report subtitle -->
        <PageHeader>
          <Height>0.5in</Height>
          <PrintOnFirstPage>true</PrintOnFirstPage>
          <PrintOnLastPage>true</PrintOnLastPage>
          <ReportItems>

            <!-- Left: Company brand -->
            <Textbox Name="HDR_Brand">
              <CanGrow>false</CanGrow>
              <Top>0.05in</Top><Left>0in</Left><Width>3in</Width><Height>0.3in</Height>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>SalesView Pro  |  Enterprise Sales Analytics</Value>
                      <Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize>
                             <FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                    </TextRun>
                  </TextRuns>
                </Paragraph>
              </Paragraphs>
              <Style><VerticalAlign>Middle</VerticalAlign></Style>
            </Textbox>

            <!-- Right: Dynamic subtitle — updates with parameter selection -->
            <Textbox Name="HDR_Subtitle">
              <CanGrow>false</CanGrow>
              <Top>0.05in</Top><Left>3in</Left><Width>3.5in</Width><Height>0.3in</Height>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>=Switch(
  Parameters!DateRange.Value="YTD",         "Year to Date",
  Parameters!DateRange.Value="LastQuarter", "Last Quarter",
  Parameters!DateRange.Value="Last12Months","Last 12 Months",
  Parameters!DateRange.Value="2024",        "Full Year 2024",
  Parameters!DateRange.Value="2023",        "Full Year 2023",
  Parameters!DateRange.Value="2022",        "Full Year 2022",
  True, Parameters!DateRange.Value
) &amp; " — " &amp; Switch(
  Parameters!RegionSegment.Value="All",        "All Regions / All Segments",
  Parameters!RegionSegment.Value="South",      "South Region",
  Parameters!RegionSegment.Value="East",       "East Region",
  Parameters!RegionSegment.Value="West",       "West Region",
  Parameters!RegionSegment.Value="North",      "North Region",
  Parameters!RegionSegment.Value="Business",   "Business Segment",
  Parameters!RegionSegment.Value="Consumer",   "Consumer Segment",
  Parameters!RegionSegment.Value="Enterprise", "Enterprise Segment",
  True, Parameters!RegionSegment.Value
)</Value>
                      <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize>
                             <FontStyle>Italic</FontStyle><Color>#595959</Color></Style>
                    </TextRun>
                  </TextRuns>
                  <Style><TextAlign>Right</TextAlign></Style>
                </Paragraph>
              </Paragraphs>
              <Style><VerticalAlign>Middle</VerticalAlign></Style>
            </Textbox>

            <!-- Bottom border line -->
            <Textbox Name="HDR_Line">
              <CanGrow>false</CanGrow>
              <Top>0.38in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.02in</Height>
              <Paragraphs><Paragraph><TextRuns><TextRun><Value></Value></TextRun></TextRuns></Paragraph></Paragraphs>
              <Style><BackgroundColor>#2E75B6</BackgroundColor></Style>
            </Textbox>

          </ReportItems>
        </PageHeader>

        <!-- PAGE FOOTER: Confidential | Page N of M | Copyright -->
        <PageFooter>
          <Height>0.4in</Height>
          <PrintOnFirstPage>true</PrintOnFirstPage>
          <PrintOnLastPage>true</PrintOnLastPage>
          <ReportItems>

            <!-- Top border line -->
            <Textbox Name="FTR_Line">
              <CanGrow>false</CanGrow>
              <Top>0in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.02in</Height>
              <Paragraphs><Paragraph><TextRuns><TextRun><Value></Value></TextRun></TextRuns></Paragraph></Paragraphs>
              <Style><BackgroundColor>#2E75B6</BackgroundColor></Style>
            </Textbox>

            <!-- Left: Confidential notice -->
            <Textbox Name="FTR_Confidential">
              <CanGrow>false</CanGrow>
              <Top>0.06in</Top><Left>0in</Left><Width>2.5in</Width><Height>0.25in</Height>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>CONFIDENTIAL — Authorized Recipients Only</Value>
                      <Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize>
                             <FontStyle>Italic</FontStyle><Color>#595959</Color></Style>
                    </TextRun>
                  </TextRuns>
                </Paragraph>
              </Paragraphs>
              <Style><VerticalAlign>Middle</VerticalAlign></Style>
            </Textbox>

            <!-- Center: Page N of M -->
            <Textbox Name="FTR_PageNumber">
              <CanGrow>false</CanGrow>
              <Top>0.06in</Top><Left>2.5in</Left><Width>1.5in</Width><Height>0.25in</Height>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>="Page " &amp; Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value>
                      <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize>
                             <FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                    </TextRun>
                  </TextRuns>
                  <Style><TextAlign>Center</TextAlign></Style>
                </Paragraph>
              </Paragraphs>
              <Style><VerticalAlign>Middle</VerticalAlign></Style>
            </Textbox>

            <!-- Right: Copyright -->
            <Textbox Name="FTR_Copyright">
              <CanGrow>false</CanGrow>
              <Top>0.06in</Top><Left>4in</Left><Width>2.5in</Width><Height>0.25in</Height>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>="Generated: " &amp; Format(Now(),"dd MMM yyyy")</Value>
                      <Style><FontFamily>Arial</FontFamily><FontSize>7.5pt</FontSize>
                             <Color>#595959</Color></Style>
                    </TextRun>
                  </TextRuns>
                  <Style><TextAlign>Right</TextAlign></Style>
                </Paragraph>
              </Paragraphs>
              <Style><VerticalAlign>Middle</VerticalAlign></Style>
            </Textbox>

          </ReportItems>
        </PageFooter>
      </Page>

      <!-- ─────────────────────────────────────────────────────────────
           REPORT BODY
           Width = 6.5in (8.5in page - 1in left - 1in right margin)
      ──────────────────────────────────────────────────────────────── -->
      <Body>
        <Height>60in</Height>
        <Width>6.5in</Width>

        <ReportItems>

          <!-- ══════════════════════════════════════════════════════
               RECTANGLE 1 — COVER PAGE
               PageBreakAfter forces all subsequent content to page 2
          ══════════════════════════════════════════════════════ -->
          <Rectangle Name="RECT_Cover">
            <Top>0in</Top><Left>0in</Left><Width>6.5in</Width><Height>9in</Height>
            <PageBreak><BreakLocation>After</BreakLocation></PageBreak>
            <ReportItems>

              <!-- Company banner -->
              <Textbox Name="CVR_Banner">
                <CanGrow>false</CanGrow>
                <Top>0.3in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.9in</Height>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>SALESVIEW PRO</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>28pt</FontSize>
                               <FontWeight>Bold</FontWeight><Color>#FFFFFF</Color></Style>
                      </TextRun>
                    </TextRuns>
                    <Style><TextAlign>Center</TextAlign></Style>
                  </Paragraph>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>Enterprise Sales Analytics Platform</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>11pt</FontSize>
                               <Color>#D6E4F0</Color></Style>
                      </TextRun>
                    </TextRuns>
                    <Style><TextAlign>Center</TextAlign></Style>
                  </Paragraph>
                </Paragraphs>
                <Style><BackgroundColor>#1E3A5F</BackgroundColor>
                       <VerticalAlign>Middle</VerticalAlign>
                       <PaddingTop>8pt</PaddingTop></Style>
              </Textbox>

              <!-- Report title -->
              <Textbox Name="CVR_Title">
                <CanGrow>false</CanGrow>
                <Top>1.4in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.75in</Height>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>SALES PERFORMANCE REPORT</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>24pt</FontSize>
                               <FontWeight>Bold</FontWeight><Color>#1E3A5F</Color></Style>
                      </TextRun>
                    </TextRuns>
                    <Style><TextAlign>Center</TextAlign></Style>
                  </Paragraph>
                </Paragraphs>
                <Style><VerticalAlign>Middle</VerticalAlign>
                       <BorderStyle><Bottom>Solid</Bottom></BorderStyle>
                       <BorderColor><Bottom>#F0A500</Bottom></BorderColor>
                       <BorderWidth><Bottom>3pt</Bottom></BorderWidth></Style>
              </Textbox>

              <!-- Dynamic subtitle from parameters -->
              <Textbox Name="CVR_ParamSubtitle">
                <CanGrow>false</CanGrow>
                <Top>2.25in</Top><Left>0in</Left><Width>6.5in</Width><Height>0.4in</Height>
                <Paragraphs>
                  <Paragraph>
                    <TextRuns>
                      <TextRun>
                        <Value>="Reporting Period: " &amp; Switch(
  Parameters!DateRange.Value="YTD","Year to Date",
  Parameters!DateRange.Value="LastQuarter","Last Quarter",
  Parameters!DateRange.Value="Last12Months","Last 12 Months",
  Parameters!DateRange.Value="2024","Full Year 2024",
  Parameters!DateRange.Value="2023","Full Year 2023",
  Parameters!DateRange.Value="2022","Full Year 2022",
  True, Parameters!DateRange.Value
) &amp; "     |     Scope: " &amp; Switch(
  Parameters!RegionSegment.Value="All","All Regions / All Segments",
  Parameters!RegionSegment.Value="South","South Region",
  Parameters!RegionSegment.Value="East","East Region",
  Parameters!RegionSegment.Value="West","West Region",
  Parameters!RegionSegment.Value="North","North Region",
  Parameters!RegionSegment.Value="Business","Business Segment",
  Parameters!RegionSegment.Value="Consumer","Consumer Segment",
  Parameters!RegionSegment.Value="Enterprise","Enterprise Segment",
  True, Parameters!RegionSegment.Value
)</Value>
                        <Style><FontFamily>Arial</FontFamily><FontSize>11pt</FontSize>
                               <FontStyle>Italic</FontStyle><Color>#2E75B6</Color></Style>
                      </TextRun>
                    </TextRuns>
                    <Style><TextAlign>Center</TextAlign></Style>
                  </Paragraph>
                </Paragraphs>
                <Style><VerticalAlign>Middle</VerticalAlign></Style>
              </Textbox>

              <!-- Metadata table -->
              <Tablix Name="CVR_MetaTable">
                <Top>2.9in</Top><Left>0.5in</Left><Width>5.5in</Width><Height>2.2in</Height>
                <TablixBody>
                  <TablixColumns>
                    <TablixColumn><Width>1.5in</Width></TablixColumn>
                    <TablixColumn><Width>4in</Width></TablixColumn>
                  </TablixColumns>
                  <TablixRows>
                    <!-- Row: Prepared For -->
                    <TablixRow>
                      <Height>0.35in</Height>
                      <TablixCells>
                        <TablixCell><CellContents><Textbox Name="M_L1"><CanGrow>false</CanGrow>
                          <Paragraphs><Paragraph><TextRuns><TextRun><Value>Prepared For:</Value>
